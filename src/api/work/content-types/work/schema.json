{
  "kind": "collectionType",
  "collectionName": "works",
  "info": {
    "singularName": "work",
    "pluralName": "works",
    "displayName": "Work",
    "description": "A musical composition. Displayed in the Work section of the site."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string",
      "required": false
    },
    "year": {
      "type": "integer",
      "required": true
    },
    "duration": {
      "type": "string",
      "required": false
    },
    "key": {
      "type": "string"
    },
    "instrumentation": {
      "type": "text"
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category",
      "mappedBy": "work"
    },
    "programNote": {
      "type": "component",
      "component": "shared.note-block",
      "repeatable": false
    },
    "performanceNote": {
      "type": "component",
      "component": "shared.note-block",
      "repeatable": false
    },
    "Lineup": {
      "type": "component",
      "component": "shared.lineup",
      "repeatable": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "links": {
      "type": "component",
      "component": "shared.link-block",
      "repeatable": true
    }
  }
}
