    "name": {
      "type": "string",
      "required": true
    },
    "images": {
      "type": "component",
      "repeatable": true,
      "component": "shared.image-item"
    },
    "links": {
      "type": "json"
    },
    "video": {
      "type": "string"
    }
  }
}
